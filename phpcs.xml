<?xml version="1.0"?>
<ruleset name="Klaviyo">
	<description>WordPress Coding Standards for Klaviyo</description>
	<file>src</file>
	<file>tests</file>
	<exclude-pattern>vendor/*</exclude-pattern>
	<rule ref="WordPress-Extra"/>
	<rule ref="WordPress-Docs"/>
	<config name="testVersion" value="8.2-"/>
	<arg value="--colors"/>
	<arg name="extensions" value="php"/>
</ruleset>
